{
  "expo": {
    "name": "Merge Kingdom",
    "slug": "merge-kingdom",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paperclip.mergekingdom"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.paperclip.mergekingdom"
    },
    "plugins": [
      "expo-router",
      "@shopify/react-native-skia"
    ],
    "scheme": "merge-kingdom"
  }
}
